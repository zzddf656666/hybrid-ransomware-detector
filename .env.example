# Copy this file to ".env" and fill in your own keys.
# The .env file is git-ignored and must NEVER be committed.

# ---- LLM semantic-analysis layer -------------------------------------------
# Backend selection: auto | ollama | openai | none
#   auto   (default) prefer a reachable local Ollama for OPSEC; fall back to
#          OpenAI only if no local model is up AND OPENAI_API_KEY is set.
#   ollama force local-only (documents never leave the machine).
#   openai force cloud (requires OPENAI_API_KEY).
#   none   disable the semantic layer entirely.
LLM_PROVIDER=auto

# Local Ollama (used by 'auto' / 'ollama'). Install from https://ollama.com,
# then e.g.  ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (used by 'auto' fallback / 'openai'). Optional — leave blank to keep
# everything local. Sending documents to the cloud is logged as egress.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# ---- VirusTotal multi-engine reputation layer ------------------------------
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here

# ---- Detection-layer data (optional overrides) -----------------------------
# Path to your fuzzy signature database (defaults to the bundled sample).
# FUZZY_SIGNATURE_DB=/path/to/fuzzy_signatures.json
# Directory of YARA rules (.yar/.yara) to compile (defaults to ./rules).
# YARA_RULES_DIR=/path/to/rules
